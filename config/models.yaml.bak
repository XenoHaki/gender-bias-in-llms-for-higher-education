defaults:
  max_output_tokens: 1500
  temperature: 0.8
  top_p: 0.9
  runs_per_name_order: 5
  worker_count: 1
  max_attempts: 5
  retry_backoff_seconds: 1.0
  retry_backoff_max: 8.0

models:
- name: chatgpt
  display_name: ChatGPT (n1n.ai)
  provider: openai
  env: N1N_API_KEY
  base_url: https://hk.n1n.ai/v1/chat/completions
  versions:
  - key: gpt-5.1-thinking-all
    display_name: GPT-5.1 Thinking (n1n.ai)
    model_id: gpt-5.1-thinking-all
  - key: gpt-5.1-chat-latest
    display_name: GPT-5.1 Chat (latest, n1n.ai)
    model_id: gpt-5.1-chat-latest
      # - key: ADD_MORE_OPENAI_MODELS_HERE
      #   display_name: Your future ChatGPT release
      #   model_id: replace-with-model-id
- name: gemini
  display_name: Gemini (n1n.ai)
  provider: openai
  env: N1N_API_KEY
  base_url: https://hk.n1n.ai/v1/chat/completions
  versions:
  - key: gemini-3-pro-preview
    display_name: Gemini 3 Pro Preview (n1n.ai)
    model_id: gemini-3-pro-preview
  - key: gemini-3-flash-preview
    display_name: Gemini 3 Flash Preview (n1n.ai)
    model_id: gemini-3-flash-preview
      # - key: gemini-1.5-pro
      #   display_name: Gemini 1.5 Pro
      #   model_id: gemini-1.5-pro
- name: claude
  display_name: Claude (n1n.ai)
  provider: openai
  env: N1N_API_KEY
  base_url: https://hk.n1n.ai/v1/chat/completions
  versions:
  - key: claude-opus-4-5-20251101-thinking
    display_name: Claude Opus 4.5 Thinking (n1n.ai)
    model_id: claude-opus-4-5-20251101-thinking
  - key: claude-opus-4-5-20251101
    display_name: Claude Opus 4.5 (n1n.ai)
    model_id: claude-opus-4-5-20251101
      # - key: opus-3
      #   display_name: Claude 3 Opus
      #   model_id: claude-3-opus-20240229
- name: llama
  display_name: Llama (Groq)
  provider: groq
  env: GROQ_API_KEY
  base_url: https://api.groq.com/openai/v1/chat/completions
  versions:
  - key: llama-3.1-70b
    display_name: Llama 3.1 70B
    model_id: llama-3.1-70b-versatile
      # - key: llama-3.1-8b
      #   display_name: Llama 3.1 8B
      #   model_id: llama-3.1-8b-instant
- name: deepseek
  display_name: DeepSeek (n1n.ai)
  provider: openai
  env: N1N_API_KEY
  base_url: https://hk.n1n.ai/v1/chat/completions
  versions:
  - key: deepseek-v3.2
    display_name: DeepSeek V3.2 (n1n.ai)
    model_id: deepseek-v3.2
  - key: deepseek-v3.2-thinking
    display_name: DeepSeek V3.2 Thinking (n1n.ai)
    model_id: deepseek-v3.2-thinking
- name: doubao
